# Copie este arquivo para .env e preencha os valores reais.
# Nao commite seu .env.

# ── Frontend (Vite / GitHub Pages) ───────────────────────────────────────────
# Controle do gate de autenticação:
#   Não definida  → auth ativo se VITE_SUPABASE_URL+ANON_KEY estiverem presentes, senão bypass
#   true          → auth sempre ativo (usado automaticamente nos testes)
#   false         → bypass total (dev sem credenciais ou demo local)
# VITE_AUTH_ENABLED=false

VITE_AUTH_PROVIDER=supabase
# Provider de dados:
#   supabase → dados direto no Supabase (GitHub Pages / sem backend)
#   bff      → dados via Express backend (padrão para self-hosted)
VITE_DATA_PROVIDER=supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Chave Anthropic para o chat IA (embutida no build — mantenha em secret no GitHub)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Stripe (assinaturas e portal de billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# URL base da API backend publicada (obrigatório fora do dev local)
VITE_API_BASE_URL=https://seu-backend.onrender.com/api

# Opcional: URL de redirect apos confirmacao de email
# VITE_AUTH_REDIRECT_URL=https://<usuario>.github.io/<repositorio>/

# Intervalo de polling do feed em ms (padrão: 10000)
# VITE_MONITOR_POLL_MS=10000

# ── Backend (Node / Render) ───────────────────────────────────────────────────
# Porta do servidor Express (padrão: 8080)
# PORT=8080

# URL do frontend (para CORS)
APP_BASE_URL=http://localhost:5173

# Supabase (service role — nunca expor no frontend)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Segredo dos cookies HttpOnly
COOKIE_SECRET=<string-aleatoria-longa>

# Anthropic API Key (backend proxy — evita expor a chave no cliente)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (assinaturas e portal de billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# ── Integração WhatsApp via Evolution API ─────────────────────────────────────
# Necessário para conectar WhatsApp e sincronizar grupos via QR code.
# Documentação: https://doc.evolution-api.com
#
# URL base da sua instância da Evolution API (sem barra final)
EVOLUTION_API_URL=https://sua-evolution-api.exemplo.com

# Chave global de autenticação da Evolution API
EVOLUTION_API_KEY=<evolution-api-key>

# ── Cookie / CORS (produção) ──────────────────────────────────────────────────
# Origens permitidas pelo CORS além de APP_BASE_URL (separadas por vírgula)
# CORS_ALLOWED_ORIGINS=https://seu-app.github.io,https://outro-dominio.com

# Configurações de segurança dos cookies
# COOKIE_SECURE=true          # Recomendado em produção (HTTPS obrigatório)
# COOKIE_SAME_SITE=lax        # 'lax', 'strict' ou 'none'
# COOKIE_DOMAIN=.seudominio.com
