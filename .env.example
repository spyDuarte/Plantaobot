# Copie este arquivo para .env e preencha os valores reais.
# Nao commite seu .env.

# ── Frontend (Vite / GitHub Pages) ───────────────────────────────────────────
# Defina como 'false' para bypass de auth em dev (ex.: demo sem Supabase configurado).
# Em produção (ou nos testes), deixe sem definir ou 'true' para exigir autenticação.
# VITE_AUTH_ENABLED=false

VITE_AUTH_PROVIDER=supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Chave Anthropic para o chat IA (embutida no build — mantenha em secret no GitHub)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Opcional: URL de redirect apos confirmacao de email
# VITE_AUTH_REDIRECT_URL=https://<usuario>.github.io/<repositorio>/
