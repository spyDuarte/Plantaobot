# Copie este arquivo para .env e preencha os valores reais
# ATENÇĂO: Nunca commite o arquivo .env no controle de versăo

# API da IA (opcional para chat)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Backend real do PlantăoBot
# Exemplo local: http://localhost:8080/api
# Exemplo produçăo: https://api.seudominio.com
VITE_API_BASE_URL=/api

# Intervalo de polling do feed em ms
VITE_MONITOR_POLL_MS=10000
